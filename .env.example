# ======================================
# Server & Environment
# ======================================
NODE_ENV=development
PORT=5000

# ======================================
# MongoDB
# ======================================
DATABASE_URL=mongodb://admin:admin123@localhost:27017/medical_erp?authSource=admin

# ======================================
# Bcrypt
# ======================================
BCRYPT_SALT_ROUNDS=15
DEFAULT_PASS=change_this_default_password

# ======================================
# Firebase Admin SDK
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
# ======================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# ======================================
# JWT
# ======================================
JWT_SECRET=change_this_to_a_random_secret_key
JWT_EXPIRES_IN=7d

# ======================================
# Redis
# ======================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ======================================
# RabbitMQ
# ======================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=rabbit123
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# ======================================
# Email (Nodemailer + College SMTP)
# ======================================
SMTP_HOST=mail.college.edu
SMTP_PORT=587
SMTP_USER=noreply@college.edu
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@college.edu

# ======================================
# Client URL (for CORS)
# ======================================
CLIENT_URL=http://localhost:3000
