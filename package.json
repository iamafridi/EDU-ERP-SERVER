{
  "name": "edu-erp-server",
  "version": "1.0.0",
  "description": "Backend API for EDU-ERP — a comprehensive college management system",
  "main": "index.js",
  "scripts": {
    "start:prod": "node ./dist/server.js",
    "start:dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/server.ts",
    "seed": "ts-node-dev --transpile-only -r dotenv/config src/scripts/seed.ts",
    "db:backup": "mongodump --uri=\"$DATABASE_URL\" --out=./backups/$(date +%Y-%m-%d)",
    "db:restore": "mongorestore --uri=\"$DATABASE_URL\"",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "lint:fix": "npx eslint src --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prettier": "prettier --ignore-path .gitignore --write \"./src**/*.+(js|ts|json)\"",
    "prettier:fix": "npx prettier --write src"
  },
  "keywords": [],
  "author": "iamafridi <afridiakbarifty@gmail.com>",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.0.0",
    "helmet": "^8.2.0",
    "http-status": "^2.1.0",
    "ioredis": "^5.11.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.16.4",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.15",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/csv-parse": "^1.1.12",
    "@types/csv-stringify": "^1.4.3",
    "@types/express": "^5.0.3",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/validator": "^13.15.2",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "globals": "^16.3.0",
    "jest": "^30.4.2",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  }
}
